# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Storage ────────────────────────────────────────────
STORAGE_BUCKET=videos

# ─── Model Configuration ───────────────────────────────
MODEL_DEVICE=cpu
EMBEDDING_DIM=256
DEVIATION_THRESHOLD=0.15

# ─── Server ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
